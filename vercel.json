{
  "version": 2,
  "builds": [
    {
      "src": "supportgpt/backend/test_vercel_import.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "config/**",
          "models/**",
          "middleware/**",
          "services/**",
          "routes/**",
          "controllers/**"
        ]
      }
    },
    {
      "src": "supportgpt/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "supportgpt/backend/test_vercel_import.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "supportgpt/frontend/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "supportgpt/frontend/$1",
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "supportgpt/frontend/index.html"
    }
  ]
}

# ChatMe - Configuration Guide
# Copy this file to `supportgpt/backend/.env` and fill in the values below.

# Server Configuration
PORT=5001
NODE_ENV=development

# Database Configuration
# MongoDB Connection String (Atlas or Local)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/chatme?retryWrites=true&w=majority

# Security
# JWT Secret Key used for signing tokens
JWT_SECRET=your_jwt_signing_secret_key_here

# AI & LLM Providers
# Gemini API Key (AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Groq API Key (Llama-3.3 Fallback Provider)
GROK_API_KEY=your_groq_api_key_here

# Vector Database (Pinecone)
# Pinecone API Key
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=chatme
PINECONE_HOST=https://your-index-host.svc.pinecone.io
PINECONE_DIMENSION=768

# CORS
# Address of the React frontend
FRONTEND_URL=http://localhost:5174
